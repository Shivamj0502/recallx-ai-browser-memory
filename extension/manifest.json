{
  "manifest_version": 3,
  "name": "Activity Memory Tracker",
  "version": "1.0",

  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "http://localhost:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}